# Public base URL of the site (no trailing slash). Used for sitemap, canonical URLs, and JSON-LD.
# Example: https://www.yoursite.com
NEXT_PUBLIC_SITE_URL=https://charlottemicrochurch.com

# Web3Forms access key (get it from the Web3Forms dashboard). The /api/contact route
# reads this on the server / Worker. Set in `wrangler.jsonc` `vars` for Cloudflare, or
# here for local `next dev` / builds.
# Optional server-only name (same value, not bundled into client):
# WEB3FORMS_ACCESS_KEY=
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
